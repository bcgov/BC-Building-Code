{
  "$defs": {
    "Appendix": {
      "properties": {
        "content": {
          "title": "Content",
          "type": "string",
          "minLength": 1,
          "maxLength": 1000000,
          "description": "Appendix content text"
        },
        "title": {
          "title": "Title",
          "type": "string",
          "minLength": 1,
          "maxLength": 500,
          "description": "Appendix title"
        },
        "page": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 1,
              "maximum": 10000
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Page",
          "description": "Page number where appendix appears"
        },
        "figureTable": {
          "anyOf": [
            {
              "$ref": "#/$defs/FigureTable"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Associated figures, tables, or formulas"
        }
      },
      "required": [
        "content",
        "title"
      ],
      "additionalProperties": false,
      "title": "Appendix",
      "type": "object"
    },
    "Article": {
      "properties": {
        "numberReference": {
          "title": "Numberreference",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+\\.[0-9]+$",
          "type": "string",
          "minLength": 7,
          "maxLength": 20,
          "description": "Article number reference (e.g., 1.1.1.1)"
        },
        "page": {
          "title": "Page",
          "type": "integer",
          "minimum": 1,
          "maximum": 10000,
          "description": "Page number where article appears"
        },
        "effectiveDates": {
          "$ref": "#/$defs/EffectiveDates"
        },
        "title": {
          "title": "Title",
          "type": "string",
          "minLength": 1,
          "maxLength": 500,
          "description": "Article title"
        },
        "sentences": {
          "items": {
            "$ref": "#/$defs/Sentence"
          },
          "title": "Sentences",
          "type": "array",
          "description": "Array of sentences within the article"
        },
        "figureTable": {
          "anyOf": [
            {
              "$ref": "#/$defs/FigureTable"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Associated figures, tables, or formulas"
        }
      },
      "required": [
        "numberReference",
        "page",
        "effectiveDates",
        "title",
        "sentences"
      ],
      "additionalProperties": false,
      "title": "Article",
      "type": "object"
    },
    "Clause": {
      "properties": {
        "numberReference": {
          "title": "Numberreference",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+\\.[0-9]+\\.\\([0-9]+\\)\\([a-z]+\\)$",
          "type": "string",
          "minLength": 12,
          "maxLength": 30,
          "description": "Clause number reference (e.g., 1.1.1.1.(1)(a))"
        },
        "page": {
          "title": "Page",
          "type": "integer",
          "minimum": 1,
          "maximum": 10000,
          "description": "Page number where clause appears"
        },
        "effectiveDates": {
          "$ref": "#/$defs/EffectiveDates"
        },
        "description": {
          "title": "Description",
          "type": "string",
          "minLength": 1,
          "maxLength": 10000,
          "description": "Clause description text"
        },
        "subClauses": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/SubClause"
              },
              "type": "array",
              "maxItems": 50
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Array of sub-clauses",
          "title": "Subclauses"
        }
      },
      "required": [
        "numberReference",
        "page",
        "effectiveDates",
        "description"
      ],
      "additionalProperties": false,
      "title": "Clause",
      "type": "object"
    },
    "EffectiveDates": {
      "properties": {
        "startDate": {
          "title": "Startdate",
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
          "description": "Start date in YYYY-MM-DD format"
        },
        "endDate": {
          "anyOf": [
            {
              "type": "string",
              "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Enddate",
          "description": "End date in YYYY-MM-DD format or null if still effective"
        }
      },
      "required": [
        "startDate"
      ],
      "title": "EffectiveDates",
      "type": "object",
      "additionalProperties": false
    },
    "Figure": {
      "properties": {
        "numberReference": {
          "title": "Numberreference",
          "pattern": "^[A-Za-z0-9.\\-\\s(),]+$",
          "type": "string",
          "minLength": 1,
          "maxLength": 50,
          "description": "Figure number reference"
        },
        "title": {
          "title": "Title",
          "type": "string",
          "minLength": 1,
          "maxLength": 500,
          "description": "Figure title"
        },
        "figureReference": {
          "title": "Figurereference",
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "Figure reference identifier"
        },
        "figureTablePosition": {
          "anyOf": [
            {
              "type": "object",
              "patternProperties": {
                "^[a-zA-Z0-9_]+$": {
                  "anyOf": [
                    {
                      "type": "integer",
                      "minimum": 0
                    },
                    {
                      "type": "string",
                      "maxLength": 100
                    }
                  ]
                }
              },
              "additionalProperties": false
            },
            {
              "type": "null"
            }
          ],
          "description": "Position information for the figure"
        },
        "figureNotes": {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 1000
              },
              "maxItems": 20
            },
            {
              "type": "null"
            }
          ],
          "description": "Notes associated with the figure"
        },
        "partOf": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 100
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "What this figure is part of",
          "title": "Partof"
        },
        "figureLabel": {
          "title": "Figurelabel",
          "type": "string",
          "minLength": 1,
          "maxLength": 200,
          "description": "Figure label text"
        },
        "figureBytes": {
          "title": "Figurebytes",
          "type": "string",
          "pattern": "^data:[^;]+;base64,[A-Za-z0-9+/]*={0,2}$",
          "minLength": 1,
          "description": "Base64 encoded figure data"
        },
        "page": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 1,
              "maximum": 10000
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Page number where figure appears",
          "title": "Page"
        }
      },
      "required": [
        "numberReference",
        "title",
        "figureReference",
        "figureLabel",
        "figureBytes"
      ],
      "additionalProperties": false,
      "title": "Figure",
      "type": "object"
    },
    "FigureTable": {
      "properties": {
        "figure": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/Figure"
              },
              "maxItems": 100,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Array of figures",
          "title": "Figure"
        },
        "table": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/Table"
              },
              "maxItems": 200,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Array of tables",
          "title": "Table"
        },
        "formula": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/Formula"
              },
              "maxItems": 100,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Array of formulas",
          "additionalProperties": false,
          "title": "Formula"
        }
      },
      "not": {
        "allOf": [
          {
            "properties": {
              "figure": {
                "type": "null"
              }
            }
          },
          {
            "properties": {
              "table": {
                "type": "null"
              }
            }
          },
          {
            "properties": {
              "formula": {
                "type": "null"
              }
            }
          }
        ]
      },
      "additionalProperties": false,
      "title": "FigureTable",
      "type": "object"
    },
    "Formula": {
      "properties": {
        "numberReference": {
          "title": "Numberreference",
          "type": "string",
          "pattern": "^[A-Za-z0-9.\\-\\s(),]+$",
          "minLength": 1,
          "maxLength": 50,
          "description": "Formula number reference"
        },
        "page": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 1,
              "maximum": 10000
            },
            {
              "type": "null"
            }
          ],
          "description": "Page number where formula appears",
          "default": null,
          "title": "Page"
        },
        "formulaTablePosition": {
          "anyOf": [
            {
              "type": "object",
              "patternProperties": {
                "^[a-zA-Z0-9_]+$": {
                  "anyOf": [
                    {
                      "type": "integer",
                      "minimum": 0
                    },
                    {
                      "type": "string",
                      "maxLength": 100
                    }
                  ]
                }
              },
              "additionalProperties": false
            },
            {
              "type": "null"
            }
          ],
          "description": "Position information for the formula"
        },
        "formulaLabel": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200,
          "description": "Formula label text"
        },
        "formulaBytes": {
          "type": "string",
          "pattern": "^data:[^;]+;base64,[A-Za-z0-9+/]*={0,2}$",
          "minLength": 1,
          "description": "Base64 encoded formula data"
        },
        "formulaLatex": {
          "type": "string",
          "minLength": 1,
          "maxLength": 5000,
          "description": "LaTeX representation of the formula"
        },
        "surroundingText": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 5000
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Text surrounding the formula",
          "title": "Surroundingtext"
        }
      },
      "required": [
        "numberReference",
        "formulaLabel",
        "formulaBytes",
        "formulaLatex"
      ],
      "additionalProperties": false,
      "title": "Formula",
      "type": "object"
    },
    "Notes": {
      "properties": {
        "numberReference": {
          "title": "Numberreference",
          "pattern": "^[A-Za-z0-9.\\-\\s(),]+$",
          "type": "string"
        },
        "page": {
          "title": "Page",
          "type": "integer",
          "minimum": 1,
          "maximum": 10000,
          "description": "Page number where notes appear"
        },
        "idx": {
          "title": "Idx",
          "type": "integer",
          "minimum": 0,
          "maximum": 1000,
          "description": "Notes index"
        },
        "effectiveDates": {
          "$ref": "#/$defs/EffectiveDates"
        },
        "title": {
          "title": "Title",
          "type": "string",
          "minLength": 1,
          "maxLength": 500,
          "description": "Notes title"
        },
        "description": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 50000
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Notes description text",
          "title": "Description"
        },
        "figureTable": {
          "anyOf": [
            {
              "$ref": "#/$defs/FigureTable"
            },
            {
              "type": "null"
            }
          ],
          "description": "Associated figures, tables, or formulas",
          "default": null
        }
      },
      "required": [
        "numberReference",
        "page",
        "idx",
        "effectiveDates",
        "title"
      ],
      "additionalProperties": false,
      "title": "Notes",
      "type": "object"
    },
    "Part": {
      "properties": {
        "numberReference": {
          "title": "Numberreference",
          "type": "string",
          "pattern": "^[0-9]+$",
          "minLength": 1,
          "maxLength": 5,
          "description": "Part number reference (e.g., 1)"
        },
        "page": {
          "title": "Page",
          "type": "integer",
          "minimum": 1,
          "maximum": 10000,
          "description": "Page number where part appears"
        },
        "effectiveDates": {
          "$ref": "#/$defs/EffectiveDates"
        },
        "title": {
          "title": "Title",
          "type": "string",
          "minLength": 1,
          "maxLength": 500,
          "description": "Part title"
        },
        "sections": {
          "items": {
            "$ref": "#/$defs/Section"
          },
          "title": "Sections",
          "type": "array",
          "minItems": 0,
          "maxItems": 100,
          "description": "Array of sections within the part"
        },
        "notes": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/Notes"
              },
              "type": "array",
              "maxItems": 500
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Notes"
        }
      },
      "required": [
        "numberReference",
        "page",
        "effectiveDates",
        "title",
        "sections"
      ],
      "additionalProperties": false,
      "title": "Part",
      "type": "object"
    },
    "Preface": {
      "properties": {
        "content": {
          "title": "Content",
          "type": "string",
          "minLength": 1,
          "maxLength": 1000000,
          "description": "Preface content text"
        },
        "page": {
          "title": "Page",
          "type": "integer",
          "minimum": 1,
          "maximum": 10000,
          "description": "Page number where preface appears"
        }
      },
      "required": [
        "content",
        "page"
      ],
      "additionalProperties": false,
      "title": "Preface",
      "type": "object"
    },
    "Section": {
      "properties": {
        "numberReference": {
          "title": "Numberreference",
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+$",
          "minLength": 3,
          "maxLength": 10,
          "description": "Section number reference (e.g., 1.1)"
        },
        "page": {
          "title": "Page",
          "type": "integer",
          "minimum": 1,
          "maximum": 10000,
          "description": "Page number where section appears"
        },
        "effectiveDates": {
          "$ref": "#/$defs/EffectiveDates"
        },
        "title": {
          "title": "Title",
          "type": "string",
          "minLength": 1,
          "maxLength": 500,
          "description": "Section title"
        },
        "subsections": {
          "items": {
            "$ref": "#/$defs/SubSection"
          },
          "title": "Subsections",
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "description": "Array of subsections within the section"
        }
      },
      "required": [
        "numberReference",
        "page",
        "effectiveDates",
        "title",
        "subsections"
      ],
      "title": "Section",
      "additionalProperties": false,
      "type": "object"
    },
    "Sentence": {
      "properties": {
        "numberReference": {
          "title": "Numberreference",
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+\\.[0-9]+\\.\\([0-9]+\\)$",
          "minLength": 1,
          "maxLength": 500,
          "description": "Sentence number reference"
        },
        "page": {
          "title": "Page",
          "type": "integer",
          "minimum": 1,
          "maximum": 10000,
          "description": "Page number where sentence appears"
        },
        "idx": {
          "title": "Idx",
          "type": "integer",
          "minimum": 0,
          "maximum": 5000,
          "description": "Sentence index"
        },
        "effectiveDates": {
          "$ref": "#/$defs/EffectiveDates"
        },
        "description": {
          "title": "Description",
          "type": "string",
          "minLength": 1,
          "maxLength": 50000,
          "description": "Sentence description text"
        },
        "figureTable": {
          "anyOf": [
            {
              "$ref": "#/$defs/FigureTable"
            },
            {
              "type": "null"
            }
          ],
          "description": "Associated figures, tables, or formulas",
          "default": null
        },
        "clauses": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/Clause"
              },
              "type": "array",
              "maxItems": 100
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Array of clauses within the sentence",
          "title": "Clauses"
        }
      },
      "required": [
        "numberReference",
        "page",
        "idx",
        "effectiveDates",
        "description"
      ],
      "additionalProperties": false,
      "title": "Sentence",
      "type": "object"
    },
    "SubClause": {
      "properties": {
        "numberReference": {
          "title": "Numberreference",
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+\\.[0-9]+\\.\\([0-9]+\\)\\([a-z]+\\)\\([ivxlc]+\\)$",
          "minLength": 15,
          "maxLength": 40,
          "description": "Sub-clause number reference (e.g., 1.1.1.1.(1)(a)(i))"
        },
        "page": {
          "title": "Page",
          "type": "integer",
          "minimum": 1,
          "maximum": 10000,
          "description": "Page number where sub-clause appears"
        },
        "effectiveDates": {
          "$ref": "#/$defs/EffectiveDates"
        },
        "text": {
          "title": "Text",
          "type": "string",
          "minLength": 1,
          "maxLength": 50000,
          "description": "Sub-clause text content"
        }
      },
      "required": [
        "numberReference",
        "page",
        "effectiveDates",
        "text"
      ],
      "additionalProperties": false,
      "title": "SubClause",
      "type": "object"
    },
    "SubSection": {
      "properties": {
        "numberReference": {
          "title": "Numberreference",
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
          "minLength": 5,
          "maxLength": 15,
          "description": "Subsection number reference (e.g., 1.1.1)"
        },
        "page": {
          "title": "Page",
          "type": "integer",
          "minimum": 1,
          "maximum": 10000,
          "description": "Page number where subsection appears"
        },
        "effectiveDates": {
          "$ref": "#/$defs/EffectiveDates"
        },
        "title": {
          "title": "Title",
          "type": "string",
          "minLength": 1,
          "maxLength": 500,
          "description": "Subsection title"
        },
        "articles": {
          "items": {
            "$ref": "#/$defs/Article"
          },
          "minItems": 0,
          "maxItems": 200,
          "title": "Articles",
          "description": "Array of articles within the subsection",
          "type": "array"
        }
      },
      "required": [
        "numberReference",
        "page",
        "effectiveDates",
        "title",
        "articles"
      ],
      "additionalProperties": false,
      "title": "SubSection",
      "type": "object"
    },
    "Table": {
      "properties": {
        "numberReference": {
          "title": "Numberreference",
          "type": "string",
          "pattern": "^[A-Za-z0-9.\\-\\s(),]+$",
          "minLength": 1,
          "maxLength": 50,
          "description": "Table number reference"
        },
        "title": {
          "title": "Title",
          "type": "string",
          "minLength": 0,
          "maxLength": 500,
          "description": "Table title"
        },
        "page": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 1,
              "maximum": 10000
            },
            {
              "type": "null"
            }
          ],
          "description": "Page number where table appears",
          "default": null,
          "title": "Page"
        },
        "tableNotes": {
          "anyOf": [
            {
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 1000
              },
              "type": "array",
              "maxItems": 20
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Notes associated with the table",
          "title": "Tablenotes"
        },
        "partOf": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 0,
              "maxLength": 200
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "What this table is part of",
          "title": "Partof"
        },
        "fields": {
          "items": {
            "type": "string",
            "minLength": 0,
            "maxLength": 2000
          },
          "minItems": 1,
          "maxItems": 50,
          "title": "Fields",
          "type": "array",
          "description": "Table column headers"
        },
        "data": {
          "items": {
            "items": {
              "type": "string",
              "maxLength": 2000
            },
            "type": "array",
            "minItems": 1,
            "maxItems": 50
          },
          "title": "Data",
          "type": "array",
          "minItems": 0,
          "maxItems": 1000,
          "description": "Table data rows"
        }
      },
      "required": [
        "numberReference",
        "title",
        "fields",
        "data"
      ],
      "additionalProperties": false,
      "title": "Table",
      "type": "object"
    }
  },
  "properties": {
    "preface": {
      "$ref": "#/$defs/Preface"
    },
    "divisionA": {
      "items": {
        "$ref": "#/$defs/Part"
      },
      "title": "Divisiona",
      "type": "array"
    },
    "divisionB": {
      "items": {
        "$ref": "#/$defs/Part"
      },
      "title": "Divisionb",
      "type": "array"
    },
    "divisionC": {
      "items": {
        "$ref": "#/$defs/Part"
      },
      "title": "Divisionc",
      "type": "array"
    },
    "appendixC": {
      "$ref": "#/$defs/Appendix"
    },
    "appendixD": {
      "$ref": "#/$defs/Appendix"
    }
  },
  "required": [
    "preface",
    "divisionA",
    "divisionB",
    "divisionC",
    "appendixC",
    "appendixD"
  ],
  "additionalProperties": false,
  "title": "BuildingCode",
  "type": "object"
}