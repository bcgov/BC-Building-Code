<?xml version="1.0" encoding="UTF-8"?>
<bc-overlay id="test-text-replacement" version="1.0" nbc-target-version="2020">
    
    <metadata>
        <title>Test Text Replacement</title>
        <description>Test global text replacement feature</description>
        <authority>Test</authority>
        <author>Test</author>
        <source-document>Test</source-document>
    </metadata>
    
    <!-- ================================================================== -->
    <!-- GLOBAL TEXT REPLACEMENTS (PRE-PROCESSING)                          -->
    <!-- ================================================================== -->
    <!-- Applied to the source document BEFORE amendments are processed.    -->
    <!-- This means subsequent amendments can reference the NEW IDs.        -->
    <!--                                                                    -->
    <!-- Use cases:                                                         -->
    <!--   - Renumbering sections (e.g., sect37 -> sect38)                  -->
    <!--   - Updating IDs when content is reorganized                       -->
    <!--   - Bulk terminology changes                                       -->
    <!--                                                                    -->
    <!-- Affects ALL text content AND ALL attribute values:                 -->
    <!--   - xml:id attributes                                              -->
    <!--   - vendor-id attributes                                           -->
    <!--   - ref target attributes                                          -->
    <!--   - Text content                                                   -->
    <!-- ================================================================== -->
    <text-replacements>
        <!-- Swapping Part 9 sec 36 and 37 to match the bc code -->
        <replace from="nbc.divBV2.part9.sect36" to="nbc.divBV2.part9.sect36_bkp"/>
        <replace from="nbc.divBV2.part9.sect37" to="nbc.divBV2.part9.sect36"/>
        <replace from="nbc.divBV2.part9.sect36_bkp" to="nbc.divBV2.part9.sect37"/>
        
        <!-- Swap display text (9.36. ↔ 9.37.) -->
        <replace from="9.36." to="9.36_bkp."/>
        <replace from="9.37." to="9.36."/>
        <replace from="9.36_bkp." to="9.37."/>
        
        <!-- Renumber existing subsect6-8 to make room for new 9.36.6 -->
        <!-- Work backwards to avoid conflicts -->
        <replace from="sect36.subsect8" to="sect36.subsect9"/>
        <replace from="9.36.8." to="9.36.9."/>
        
        <replace from="sect36.subsect7" to="sect36.subsect8"/>
        <replace from="9.36.7." to="9.36.8."/>
        
        <replace from="sect36.subsect6" to="sect36.subsect7"/>
        <replace from="9.36.6." to="9.36.7."/>
        
        <replace from="nbc.divBV2.part9.sect37" to="nbc.divBV2.part9.sect38"/>

        
        <!-- Swap display text (9.37. ↔ 9.38.) -->
        <replace from="9.37." to="9.38."/>
 
        
        <!-- Regex replacement (set regex="true") -->
        <!-- <replace from="sect37" to="sect38"/> -->
        <!-- <replace from="9\.37\.(\d+)" to="9.38.$1" regex="true"/> -->
    </text-replacements>
</bc-overlay>
